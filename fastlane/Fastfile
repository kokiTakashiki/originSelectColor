# frozen_string_literal: true

default_platform(:ios)

platform :ios do

  desc "Build and upload to TestFlight"
  lane :beta do

    # ビルド番号は GitHub Actions の実行番号を使用
    build_number = ENV["GITHUB_RUN_NUMBER"] || "1"
    increment_build_number(
      build_number: build_number,
      xcodeproj: "originSelectColor.xcodeproj"
    )

    # 一時キーチェーンの作成と証明書のインポート
    keychain_name = "build.keychain"
    keychain_password = "temp_keychain_password"

    begin
      create_keychain(
        name: keychain_name,
        password: keychain_password,
        default_keychain: true,
        unlock: true,
        timeout: 3600,
        lock_when_sleeps: false
      )

      import_certificate(
        certificate_path: ENV["CERTIFICATE_PATH"],
        certificate_password: ENV["CERTIFICATE_PASSWORD"],
        keychain_name: keychain_name,
        keychain_password: keychain_password
      )

      install_provisioning_profile(
        path: ENV["PROVISIONING_PROFILE_PATH"]
      )

      # アーカイブ（手動コード署名でオーバーライド）
      gym(
        scheme: "originSelectColor",
        project: "originSelectColor.xcodeproj",
        configuration: "Release",
        export_method: "app-store",
        output_directory: "./build",
        output_name: "originSelectColor.ipa",
        xcargs: [
          "CODE_SIGN_STYLE=Manual",
          "DEVELOPMENT_TEAM='#{ENV['DEVELOPMENT_TEAM']}'",
          "CODE_SIGN_IDENTITY='Apple Distribution'",
          "PROVISIONING_PROFILE_SPECIFIER='#{ENV['PROVISIONING_PROFILE_NAME']}'"
        ].join(" "),
        export_options: {
          method: "app-store",
          teamID: ENV["DEVELOPMENT_TEAM"],
          signingStyle: "manual",
          provisioningProfiles: {
            ENV["PRODUCT_BUNDLE_IDENTIFIER"] => ENV["PROVISIONING_PROFILE_NAME"]
          }
        },
        clean: true
      )

      # TestFlight へアップロード
      api_key = app_store_connect_api_key(
        key_id: ENV["APPSTORECONNECT_KEY_ID"],
        issuer_id: ENV["APPSTORECONNECT_ISSUER_ID"],
        key_content: ENV["APPSTORECONNECT_KEY_CONTENT"],
        is_key_content_base64: true,
        duration: 1200,
        in_house: false
      )

      upload_to_testflight(
        api_key: api_key,
        ipa: "./build/originSelectColor.ipa",
        skip_waiting_for_build_processing: true,
        changelog: "Build #{build_number} — automated upload from GitHub Actions"
      )

    ensure
      delete_keychain(name: keychain_name)
    end
  end

end
